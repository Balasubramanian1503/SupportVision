datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      String // "AGENT" | "CUSTOMER"
  createdAt DateTime @default(now())
}

model Session {
  id              String               @id @default(uuid())
  title           String
  status          String // "ACTIVE" | "ENDED"
  createdAt       DateTime             @default(now())
  endedAt         DateTime?
  recordingPath   String?
  recordingStatus String? // "RECORDING" | "PROCESSING" | "READY"
  participants    SessionParticipant[]
  messages        ChatMessage[]
  events          SessionEvent[]
}

model SessionParticipant {
  id          String    @id @default(uuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId      String? // Nullable for guests
  displayName String
  role        String // "AGENT" | "CUSTOMER" | "GUEST"
  joinedAt    DateTime  @default(now())
  leftAt      DateTime?
}

model ChatMessage {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  senderId   String? // Nullable for guests
  senderName String
  message    String
  fileUrl    String? // For attachments
  fileName   String?
  fileType   String?
  createdAt  DateTime @default(now())
}

model SessionEvent {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  eventType String // "JOIN" | "LEAVE" | "START_RECORDING" | "STOP_RECORDING" | "FORCE_END"
  userId    String?
  details   String?
  timestamp DateTime @default(now())
}
